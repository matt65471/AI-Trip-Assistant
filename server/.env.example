# OpenAI (required for itinerary and chat)
OPENAI_API_KEY=

# Google Geocoding (required for location validation)
GOOGLE_GEOCODING_API_KEY=

# SerpAPI (required for flight search - get a key at serpapi.com)
SERPAPI_API_KEY=

# SkyLink via RapidAPI (optional - for airport search by city; fallback list used if missing)
# Get key at https://rapidapi.com/skylink-api-skylink-api-default/api/skylink-api
SKYLINK_RAPIDAPI_KEY=
