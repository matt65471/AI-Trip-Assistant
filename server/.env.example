# OpenAI (required for itinerary and chat)
OPENAI_API_KEY=

# Google Geocoding (required for location validation)
GOOGLE_GEOCODING_API_KEY=

# Amadeus (required for flight search - free tier at developers.amadeus.com)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# Optional: use 'production' for live data (default: 'test')
# AMADEUS_HOST=test
